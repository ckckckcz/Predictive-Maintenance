APP_PORT=8080
APP_ENV=development

# ============================================================
# SUPABASE / POSTGRESQL
# ============================================================
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL_DIRECT=postgresql://postgres:[db-password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Pool settings
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

JWT_SECRET=your-super-secret-key-min-32-chars-here
JWT_ACCESS_EXPIRES=15m      
JWT_REFRESH_EXPIRES=168h      

CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# WEB PUSH PWA (VAPID)
# ============================================================
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com


EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# ============================================================
# SIMULATOR UNTUK SENSOR MESIN
# ============================================================
SIMULATOR_API_KEY=sim-secret-key-here
