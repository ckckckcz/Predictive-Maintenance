{
  "version": 2,
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.go"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/simulate",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/cron/recalculate-risk",
      "schedule": "0 0 * * *"
    }
  ]
}
